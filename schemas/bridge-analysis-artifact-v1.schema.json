{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/chrober/bliss-playlist-optimizer/schemas/bridge-analysis-artifact-v1.schema.json",
  "title": "Contextual bridge analysis artifact v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "artifact_kind", "program", "version", "core_api",
    "job_id", "request_sha256", "database_sha256", "learned_matrix_sha256",
    "semantic_evidence_sha256", "algorithm_requested", "learned_percent",
    "seed_limit", "deterministic_seed", "restart_count", "parallel_execution",
    "selected_strategy", "selected_track_ids", "selected_route_objective",
    "usable_library_track_count", "eligible_candidate_count",
    "frozen_reference_count", "trigger_percentile", "max_leg_percentile",
    "max_detour_percentile", "retained_candidate_limit", "semantic_mode",
    "provider_states", "gaps"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "artifact_kind": { "const": "contextual-bridge-analysis-v1" },
    "program": { "const": "bliss-playlist-optimizer" },
    "version": { "type": "string" },
    "core_api": { "type": "string" },
    "job_id": { "type": "string", "minLength": 1 },
    "request_sha256": { "$ref": "#/$defs/sha256" },
    "database_sha256": { "$ref": "#/$defs/sha256" },
    "learned_matrix_sha256": { "$ref": "#/$defs/sha256" },
    "semantic_evidence_sha256": { "$ref": "#/$defs/sha256" },
    "algorithm_requested": { "const": "adaptive" },
    "learned_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
    "seed_limit": { "type": "integer", "minimum": 1 },
    "deterministic_seed": { "type": "integer", "minimum": 0 },
    "restart_count": { "type": "integer", "minimum": 0 },
    "parallel_execution": { "const": "rayon-route-restarts-and-candidates-indexed" },
    "selected_strategy": { "enum": ["adaptive", "adaptive-arc"] },
    "selected_track_ids": { "$ref": "#/$defs/track_ids" },
    "selected_route_objective": { "type": "number", "minimum": 0 },
    "usable_library_track_count": { "type": "integer", "minimum": 2 },
    "eligible_candidate_count": { "type": "integer", "minimum": 0 },
    "frozen_reference_count": { "type": "integer", "minimum": 1 },
    "trigger_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
    "max_leg_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
    "max_detour_percentile": { "type": "number", "minimum": 0 },
    "retained_candidate_limit": { "type": "integer", "minimum": 1 },
    "semantic_mode": {
      "enum": [
        "bliss-only-empty-graph",
        "bliss-only-no-usable-edges",
        "semantic-assisted"
      ]
    },
    "provider_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/provider_state" }
    },
    "gaps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/gap" }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "track_ids": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "position", "left_track_id", "right_track_id", "direct_distance",
        "direct_percentile", "triggering", "semantic_pool",
        "semantic_candidate_count", "semantic_excluded_count",
        "evaluated_candidate_count",
        "accepted_candidate_count", "repeat_rejected_count",
        "acoustic_rejected_count", "accepted_candidates"
      ],
      "properties": {
        "position": { "type": "integer", "minimum": 1 },
        "left_track_id": { "type": "string", "minLength": 1 },
        "right_track_id": { "type": "string", "minLength": 1 },
        "direct_distance": { "type": "number", "minimum": 0 },
        "direct_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
        "triggering": { "type": "boolean" },
        "semantic_pool": {
          "enum": ["endpoint_local", "collection_fallback", "bliss_only"]
        },
        "semantic_candidate_count": { "type": "integer", "minimum": 0 },
        "semantic_excluded_count": { "type": "integer", "minimum": 0 },
        "evaluated_candidate_count": { "type": "integer", "minimum": 0 },
        "accepted_candidate_count": { "type": "integer", "minimum": 0 },
        "repeat_rejected_count": { "type": "integer", "minimum": 0 },
        "acoustic_rejected_count": { "type": "integer", "minimum": 0 },
        "accepted_candidates": {
          "type": "array",
          "items": { "$ref": "#/$defs/candidate" }
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id", "semantic_tier", "semantic_evidence",
        "left_distance", "right_distance", "left_percentile",
        "right_percentile", "max_percentile", "detour_percentile"
      ],
      "properties": {
        "candidate_id": { "type": "string", "pattern": "^bliss-row-[1-9][0-9]*$" },
        "semantic_tier": {
          "enum": [
            "recording_both", "recording_one", "artist_local",
            "artist_collection", "bliss_only"
          ]
        },
        "semantic_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/matched_evidence" }
        },
        "left_distance": { "type": "number", "minimum": 0 },
        "right_distance": { "type": "number", "minimum": 0 },
        "left_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
        "right_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
        "max_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
        "detour_percentile": { "type": "number", "minimum": 0 }
      }
    },
    "provider_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "state"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "dataset_or_algorithm": { "type": "string" },
        "state": {
          "enum": [
            "disabled", "fresh", "cached", "stale", "partial",
            "unavailable", "failed"
          ]
        },
        "request_count": { "type": "integer", "minimum": 0 },
        "failure_count": { "type": "integer", "minimum": 0 },
        "error_codes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "matched_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider", "source_endpoint", "source_id", "kind", "scope",
        "identity_confidence"
      ],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "dataset_or_algorithm": { "type": "string" },
        "source_endpoint": { "enum": ["left", "right", "collection"] },
        "source_id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["recording", "artist"] },
        "scope": { "enum": ["endpoint_local", "collection_fallback"] },
        "raw_rank": { "type": "integer", "minimum": 1 },
        "raw_score": { "type": "number" },
        "identity_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "observed_at": { "type": "string", "format": "date-time" },
        "cache_state": { "enum": ["fresh", "cached", "stale"] }
      },
      "anyOf": [
        { "required": ["raw_rank"] },
        { "required": ["raw_score"] }
      ]
    }
  }
}
