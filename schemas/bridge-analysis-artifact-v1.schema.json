{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/chrober/bliss-playlist-optimizer/schemas/bridge-analysis-artifact-v1.schema.json",
  "title": "Contextual bridge analysis artifact v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "artifact_kind", "program", "version", "core_api",
    "job_id", "request_sha256", "database_sha256", "learned_matrix_sha256",
    "semantic_evidence_sha256", "algorithm_requested", "ordering_policy",
    "learned_percent",
    "seed_limit", "deterministic_seed", "restart_count", "parallel_execution",
    "selected_strategy", "source_track_ids", "selected_track_ids",
    "selected_route_objective",
    "usable_library_track_count", "eligible_candidate_count",
    "frozen_reference_count", "trigger_percentile", "max_leg_percentile",
    "max_detour_percentile", "retained_candidate_limit", "semantic_mode",
    "provider_states", "gaps", "selection_preview"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "artifact_kind": { "const": "contextual-bridge-analysis-v1" },
    "program": { "const": "bliss-playlist-optimizer" },
    "version": { "type": "string" },
    "core_api": { "type": "string" },
    "job_id": { "type": "string", "minLength": 1 },
    "request_sha256": { "$ref": "#/$defs/sha256" },
    "database_sha256": { "$ref": "#/$defs/sha256" },
    "learned_matrix_sha256": { "$ref": "#/$defs/sha256" },
    "semantic_evidence_sha256": { "$ref": "#/$defs/sha256" },
    "algorithm_requested": { "const": "adaptive" },
    "ordering_policy": { "enum": ["optimize_order", "preserve_order"] },
    "learned_percent": { "type": "integer", "minimum": 0, "maximum": 100 },
    "seed_limit": { "type": "integer", "minimum": 1 },
    "deterministic_seed": { "type": "integer", "minimum": 0 },
    "restart_count": { "type": "integer", "minimum": 0 },
    "parallel_execution": {
      "enum": [
        "rayon-route-restarts-and-candidates-indexed",
        "rayon-candidates-indexed"
      ]
    },
    "selected_strategy": {
      "enum": ["adaptive", "adaptive-arc", "preserve-order"]
    },
    "source_track_ids": { "$ref": "#/$defs/track_ids" },
    "selected_track_ids": { "$ref": "#/$defs/track_ids" },
    "selected_route_objective": { "type": "number", "minimum": 0 },
    "usable_library_track_count": { "type": "integer", "minimum": 2 },
    "eligible_candidate_count": { "type": "integer", "minimum": 0 },
    "frozen_reference_count": { "type": "integer", "minimum": 1 },
    "trigger_percentile": {
      "anyOf": [
        { "type": "number", "minimum": 0, "maximum": 1 },
        { "type": "null" }
      ]
    },
    "max_leg_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
    "max_detour_percentile": { "type": "number", "minimum": 0 },
    "retained_candidate_limit": { "type": "integer", "minimum": 1 },
    "semantic_mode": {
      "enum": [
        "bliss-only-empty-graph",
        "bliss-only-no-usable-edges",
        "semantic-assisted"
      ]
    },
    "provider_states": {
      "type": "array",
      "items": { "$ref": "#/$defs/provider_state" }
    },
    "gaps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/gap" }
    },
    "selection_preview": {
      "oneOf": [
        { "$ref": "#/$defs/automatic_selection_preview" },
        { "$ref": "#/$defs/exact_selection_preview" }
      ]
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "track_ids": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1 }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "position", "left_track_id", "right_track_id", "direct_distance",
        "direct_percentile", "triggering", "semantic_pool",
        "semantic_candidate_count", "semantic_excluded_count",
        "evaluated_candidate_count",
        "accepted_candidate_count", "repeat_rejected_count",
        "acoustic_rejected_count", "accepted_candidates"
      ],
      "properties": {
        "position": { "type": "integer", "minimum": 1 },
        "left_track_id": { "type": "string", "minLength": 1 },
        "right_track_id": { "type": "string", "minLength": 1 },
        "direct_distance": { "type": "number", "minimum": 0 },
        "direct_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
        "triggering": {
          "anyOf": [
            { "type": "boolean" },
            { "type": "null" }
          ]
        },
        "semantic_pool": {
          "enum": ["endpoint_local", "collection_fallback", "bliss_only"]
        },
        "semantic_candidate_count": { "type": "integer", "minimum": 0 },
        "semantic_excluded_count": { "type": "integer", "minimum": 0 },
        "evaluated_candidate_count": { "type": "integer", "minimum": 0 },
        "accepted_candidate_count": { "type": "integer", "minimum": 0 },
        "repeat_rejected_count": { "type": "integer", "minimum": 0 },
        "acoustic_rejected_count": { "type": "integer", "minimum": 0 },
        "accepted_candidates": {
          "type": "array",
          "items": { "$ref": "#/$defs/candidate" }
        }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id", "semantic_tier", "semantic_evidence",
        "left_distance", "right_distance", "left_percentile",
        "right_percentile", "max_percentile", "detour_percentile"
      ],
      "properties": {
        "candidate_id": { "type": "string", "pattern": "^bliss-row-[1-9][0-9]*$" },
        "semantic_tier": {
          "enum": [
            "recording_both", "recording_one", "artist_local",
            "artist_collection", "bliss_only"
          ]
        },
        "semantic_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/matched_evidence" }
        },
        "left_distance": { "type": "number", "minimum": 0 },
        "right_distance": { "type": "number", "minimum": 0 },
        "left_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
        "right_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
        "max_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
        "detour_percentile": { "type": "number", "minimum": 0 }
      }
    },
    "provider_state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "state"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "dataset_or_algorithm": { "type": "string" },
        "state": {
          "enum": [
            "disabled", "fresh", "cached", "stale", "partial",
            "unavailable", "failed"
          ]
        },
        "request_count": { "type": "integer", "minimum": 0 },
        "failure_count": { "type": "integer", "minimum": 0 },
        "error_codes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "matched_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider", "source_endpoint", "source_id", "kind", "scope",
        "identity_confidence"
      ],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "dataset_or_algorithm": { "type": "string" },
        "source_endpoint": { "enum": ["left", "right", "collection"] },
        "source_id": { "type": "string", "minLength": 1 },
        "kind": { "enum": ["recording", "artist"] },
        "scope": { "enum": ["endpoint_local", "collection_fallback"] },
        "raw_rank": { "type": "integer", "minimum": 1 },
        "raw_score": { "type": "number" },
        "identity_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "observed_at": { "type": "string", "format": "date-time" },
        "cache_state": { "enum": ["fresh", "cached", "stale"] }
      },
      "anyOf": [
        { "required": ["raw_rank"] },
        { "required": ["raw_score"] }
      ]
    },
    "automatic_selection_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode", "processing_order", "max_added_tracks", "added_track_count",
        "original_subsequence_preserved", "unique_membership",
        "final_sequence", "decisions"
      ],
      "properties": {
        "mode": { "const": "automatic" },
        "processing_order": { "const": "left-to-right-original-gaps" },
        "max_added_tracks": { "type": "integer", "minimum": 0 },
        "added_track_count": { "type": "integer", "minimum": 0 },
        "original_subsequence_preserved": { "const": true },
        "unique_membership": { "const": true },
        "final_sequence": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/preview_sequence_entry" }
        },
        "decisions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/preview_decision" }
        }
      }
    },
    "exact_selection_preview": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode", "processing_order", "requested_added_tracks", "feasible",
        "added_track_count", "original_subsequence_preserved",
        "unique_membership", "final_sequence", "decisions", "search",
        "infeasibility"
      ],
      "properties": {
        "mode": { "const": "exact_count" },
        "processing_order": {
          "const": "left-to-right-original-gaps-beam-search"
        },
        "requested_added_tracks": { "type": "integer", "minimum": 0 },
        "feasible": { "type": "boolean" },
        "added_track_count": { "type": "integer", "minimum": 0 },
        "original_subsequence_preserved": {
          "anyOf": [{ "const": true }, { "type": "null" }]
        },
        "unique_membership": {
          "anyOf": [{ "const": true }, { "type": "null" }]
        },
        "final_sequence": {
          "anyOf": [
            {
              "type": "array",
              "minItems": 2,
              "items": { "$ref": "#/$defs/preview_sequence_entry" }
            },
            { "type": "null" }
          ]
        },
        "decisions": {
          "type": "array",
          "items": { "$ref": "#/$defs/exact_preview_decision" }
        },
        "search": { "$ref": "#/$defs/exact_search" },
        "infeasibility": {
          "anyOf": [
            { "$ref": "#/$defs/exact_infeasibility" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "feasible": { "const": true } } },
          "then": {
            "properties": {
              "original_subsequence_preserved": { "const": true },
              "unique_membership": { "const": true },
              "final_sequence": {
                "type": "array",
                "minItems": 2,
                "items": { "$ref": "#/$defs/preview_sequence_entry" }
              },
              "infeasibility": { "type": "null" }
            }
          },
          "else": {
            "properties": {
              "added_track_count": { "const": 0 },
              "original_subsequence_preserved": { "type": "null" },
              "unique_membership": { "type": "null" },
              "final_sequence": { "type": "null" },
              "decisions": { "maxItems": 0 },
              "infeasibility": { "$ref": "#/$defs/exact_infeasibility" }
            }
          }
        }
      ]
    },
    "exact_search": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "beam_width", "candidate_limit", "evaluated_states",
        "retained_states", "maximum_additions_found",
        "structural_upper_bound"
      ],
      "properties": {
        "beam_width": { "type": "integer", "minimum": 1 },
        "candidate_limit": { "type": "integer", "minimum": 1 },
        "evaluated_states": { "type": "integer", "minimum": 1 },
        "retained_states": { "type": "integer", "minimum": 1 },
        "maximum_additions_found": { "type": "integer", "minimum": 0 },
        "structural_upper_bound": { "type": "integer", "minimum": 0 }
      }
    },
    "exact_infeasibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code", "requested_added_tracks", "maximum_additions_found",
        "structural_upper_bound"
      ],
      "properties": {
        "code": {
          "enum": [
            "EXACT_COUNT_INFEASIBLE",
            "EXACT_COUNT_NOT_FOUND_WITHIN_SEARCH_BOUNDS"
          ]
        },
        "requested_added_tracks": { "type": "integer", "minimum": 0 },
        "maximum_additions_found": { "type": "integer", "minimum": 0 },
        "structural_upper_bound": { "type": "integer", "minimum": 0 }
      }
    },
    "exact_preview_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original_position", "route_position", "left_track_id",
        "right_track_id", "direct_distance", "direct_percentile",
        "semantic_pool", "reason", "selected_bridge"
      ],
      "properties": {
        "original_position": { "type": "integer", "minimum": 1 },
        "route_position": { "type": "integer", "minimum": 1 },
        "left_track_id": { "type": "string", "minLength": 1 },
        "right_track_id": { "type": "string", "minLength": 1 },
        "direct_distance": { "type": "number", "minimum": 0 },
        "direct_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
        "semantic_pool": {
          "enum": ["endpoint_local", "collection_fallback", "bliss_only"]
        },
        "reason": { "enum": ["selected", "not_selected"] },
        "selected_bridge": {
          "anyOf": [
            { "$ref": "#/$defs/candidate" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "reason": { "const": "selected" } } },
          "then": {
            "properties": {
              "selected_bridge": { "$ref": "#/$defs/candidate" }
            }
          },
          "else": {
            "properties": { "selected_bridge": { "type": "null" } }
          }
        }
      ]
    },
    "preview_sequence_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["position", "kind", "track_id"],
      "properties": {
        "position": { "type": "integer", "minimum": 0 },
        "kind": { "enum": ["original", "bridge"] },
        "track_id": { "type": "string", "minLength": 1 }
      }
    },
    "preview_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "original_position", "route_position", "left_track_id",
        "right_track_id", "direct_distance", "direct_percentile", "triggering",
        "semantic_pool", "reason", "selected_bridge"
      ],
      "properties": {
        "original_position": { "type": "integer", "minimum": 1 },
        "route_position": { "type": "integer", "minimum": 1 },
        "left_track_id": { "type": "string", "minLength": 1 },
        "right_track_id": { "type": "string", "minLength": 1 },
        "direct_distance": { "type": "number", "minimum": 0 },
        "direct_percentile": { "type": "number", "minimum": 0, "maximum": 1 },
        "triggering": { "type": "boolean" },
        "semantic_pool": {
          "enum": ["endpoint_local", "collection_fallback", "bliss_only"]
        },
        "reason": {
          "enum": [
            "selected", "below_threshold", "budget_exhausted",
            "no_eligible_candidate", "repeat_conflict", "acoustic_rejected",
            "no_improvement"
          ]
        },
        "selected_bridge": {
          "anyOf": [
            { "$ref": "#/$defs/candidate" },
            { "type": "null" }
          ]
        }
      },
      "allOf": [
        {
          "if": { "properties": { "reason": { "const": "selected" } } },
          "then": {
            "properties": {
              "selected_bridge": { "$ref": "#/$defs/candidate" }
            }
          },
          "else": {
            "properties": { "selected_bridge": { "type": "null" } }
          }
        }
      ]
    }
  }
}
